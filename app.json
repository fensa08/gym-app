{
  "expo": {
    "name": "Gym Tracker",
    "slug": "gym-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "gymtracker",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fensa08.gymtracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f6f8ef",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.fensa08.gymtracker"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
